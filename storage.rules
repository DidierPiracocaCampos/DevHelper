rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // User files: only the owner can read or write under users/{userId}/files/**
    match /users/{userId}/files/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User custom NASA image: only the owner can read or write under users/{userId}/nasa-image/**
    match /users/{userId}/nasa-image/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
